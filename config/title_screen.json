{
  "window": {
    "width": 512,
    "height": 384,
    "virtual_width": 512,
    "virtual_height": 384,
    "design_width": 1024,
    "design_height": 768,
    "title": "Pokemon Resort"
  },
  "assets": {
    "background_a": "assets/title/background_a.png",
    "background_b": "assets/title/background_b.png",
    "button_main": "assets/title/btn_main.png",
    "logo_splash": "assets/title/logo_splash.png",
    "logo_main": "assets/title/logo_main.png",
    "logo_main_mask": "",
    "font": "assets/fonts/Arial.ttf"
  },
  "timings": {
    "splash_fade_in": 2.55,
    "splash_hold": 1,
    "splash_fade_out": 1,
    "main_logo_on_black": 2,
    "white_flash": 1.0,
    "title_hold_before_prompt": 1.80,
    "start_transition": 0.60
  },
  "prompt": {
    "text": "PRESS START",
    "center_x": 512,
    "baseline_y": 724,
    "font_pt_size": 72,
    "blink_cycle_seconds": 1.60,
    "color": {
      "r": 160,
      "g": 160,
      "b": 160,
      "a": 255
    }
  },
  "layout": {
    "splash_logo_center": { "x": 512, "y": 384 },
    "main_logo_center": { "x": 512, "y": 384 },
    "background_a_top_left": { "x": 0, "y": 0 },
    "background_b_top_left": { "x": 0, "y": 0 }
  },
  "transition": {
    "main_logo_end_y": -260,
    "background_a_end_y": -768,
    "background_a_speed_scale": 0.8,
    "main_logo_speed_scale": 1.0,
    "fade_prompt_out": true
  },
  "menu": {
    "items": [
      "RESORT",
      "TRANSFER",
      "OPTIONS"
    ],
    "center_x": 512,
    "top_y": 40,
    "vertical_spacing": 40,
    "font_pt_size": 44,
    "animation": {
      "intro_duration": 0.5,
      "outro_duration": 0.35,
      "slide_distance": 420,
      "bounce": 0.1
    },
    "selection": {
      "beat_speed": 15,
      "beat_magnitude": 0.01
    },
    "section_transition": {
      "button_out_duration": 0.3,
      "fade_duration": 0.25
    },
    "text_color": {
      "r": 255,
      "g": 255,
      "b": 255,
      "a": 255
    }
  },
  "input": {
    "accept_any_key": true,
    "accept_mouse": true,
    "accept_controller": true,
    "navigate_up_keys": ["UP", "W"],
    "navigate_down_keys": ["DOWN", "S"],
    "forward_keys": ["M", "RETURN", "SPACE"],
    "back_keys": ["N", "ESCAPE", "BACKSPACE"]
  },
  "audio": {
    "menu_music": "assets/title/menu_music.mp3",
    "button_sfx": "assets/title/btn.mp3",
    "music_volume": 3,
    "sfx_volume": 8
  },
  "persistence": {
    "save_options": true,
    "organization": "VantaStudio",
    "application": "PokemonResort",
    "save_file_name": "pokemon_resort.sav",
    "backup_file_name": "pokemon_resort.sav.bak"
  },
  "skip": {
    "splash_fade_in": false,
    "splash_hold": true,
    "splash_fade_out": true,
    "main_logo_on_black": true,
    "white_flash": true,
    "title_hold": true,
    "waiting_for_start": false,
    "start_transition": false,
    "main_menu_intro": false,
    "main_menu_idle": false
  },
  "shine": {
    "repeat_count": 2,
    "gap_seconds": 5.5,
    "band_width": 90,
    "travel_padding": 140
  }
}
